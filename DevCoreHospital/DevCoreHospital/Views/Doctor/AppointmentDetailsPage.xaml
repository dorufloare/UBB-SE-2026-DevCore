<Page
    x:Class="DevCoreHospital.Views.Doctor.AppointmentDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<ScrollViewer>
		<Grid Padding="24" RowSpacing="16">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<TextBlock Text="Appointment Details"
                       FontSize="40"
                       FontWeight="SemiBold"/>

			<Border Grid.Row="1"
                    Background="#F3F4F6"
                    CornerRadius="16"
                    Padding="16">
				<StackPanel Spacing="10">
					<TextBlock Text="{Binding TypeLine}" FontSize="20" FontWeight="SemiBold"/>
					<TextBlock Text="{Binding LocationLine}" FontSize="18"/>
					<TextBlock Text="{Binding StatusLine}" FontSize="18"/>
					<TextBlock Text="{Binding TimeLine}" FontSize="18"/>
				</StackPanel>
			</Border>

			<Button Grid.Row="2"
                    Content="Back"
                    Width="120"
                    HorizontalAlignment="Left"
                    Click="Back_Click"/>
		</Grid>
	</ScrollViewer>
</Page>