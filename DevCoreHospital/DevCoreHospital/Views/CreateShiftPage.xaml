<UserControl
    x:Class="DevCoreHospital.Views.CreateShiftPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#FF0B120D"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF0F1711"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FFB7C2BA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgBrush}" Padding="24">

        <Border Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="350">

            <StackPanel Spacing="15">
                <TextBlock Text="Programare Tură Nouă"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="24" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <ComboBox x:Name="EmployeeComboBox"
                          Header="Personal medical"
                          PlaceholderText="Alege angajatul"
                          HorizontalAlignment="Stretch"
                          Foreground="{StaticResource TextBrush}"/>

                <CalendarDatePicker x:Name="ShiftDatePicker"
                                    Header="Data calendaristică"
                                    HorizontalAlignment="Stretch"
                                    Foreground="{StaticResource TextBrush}"/>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TimePicker x:Name="StartTimePicker" Header="Start" 
                                Grid.Column="0" HorizontalAlignment="Stretch" 
                                Foreground="{StaticResource TextBrush}"/>

                    <TimePicker x:Name="EndTimePicker" Header="Final" 
                                Grid.Column="1" HorizontalAlignment="Stretch" 
                                Foreground="{StaticResource TextBrush}"/>
                </Grid>

                <Button Content="Confirmă Tura"
                        Click="SaveShift_Click"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Padding="10"
                        Margin="0,10,0,0"/>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>