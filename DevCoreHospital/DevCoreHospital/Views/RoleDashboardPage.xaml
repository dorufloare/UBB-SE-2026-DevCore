<Page
    x:Class="DevCoreHospital.Views.RoleDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#FF000000"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FF0F0F0F"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF131313"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>


        <Style x:Key="MenuItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left menu -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="0,0,1,0">
            <Grid Padding="16" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="DevCore Hospital"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="RoleText"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <ListView x:Name="MenuList"
                          Grid.Row="1"
                          SelectionChanged="MenuList_SelectionChanged"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemContainerStyle="{StaticResource MenuItemContainerStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                                    Padding="0"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1">
                                <Grid Height="56">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="10,0,0,10"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Row="2"
                        Content="Change Role"
                        Click="ChangeRole_Click"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        BorderBrush="{StaticResource AccentBrush}"/>
            </Grid>
        </Border>

        <!-- Right content -->
        <Grid Grid.Column="1" Background="#FF111111">
            <Frame x:Name="ContentFrame"/>
        </Grid>
    </Grid>
</Page>